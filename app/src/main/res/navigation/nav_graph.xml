<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/nav_graph"
    app:startDestination="@id/splashFragment">

    <fragment
        android:id="@+id/splashFragment"
        android:name="com.example.lingo.ui.SplashFragment"
        android:label="SplashFragment" >
        <action
            android:id="@+id/action_splash_to_home"
            app:destination="@id/homeFragment"
            app:popUpTo="@id/splashFragment"
            app:popUpToInclusive="true"
            app:enterAnim="@android:anim/fade_in"
            app:exitAnim="@android:anim/fade_out" />
    </fragment>

    <fragment
        android:id="@+id/homeFragment"
        android:name="com.example.lingo.ui.HomeFragment"
        android:label="HomeFragment" >

        <action
            android:id="@+id/action_home_to_card"
            app:destination="@id/cardFragment"
            app:enterAnim="@android:anim/fade_in"
            app:exitAnim="@android:anim/fade_out" />

        <action
                android:id="@+id/action_home_to_settings"
                app:destination="@id/settingsFragment"
                app:enterAnim="@android:anim/fade_in"
                app:exitAnim="@android:anim/fade_out" />

        <action
                android:id="@+id/action_home_to_about"
                app:destination="@id/aboutFragment"
                app:enterAnim="@android:anim/fade_in"
                app:exitAnim="@android:anim/fade_out" />
        </fragment>

    <fragment
        android:id="@+id/cardFragment"
        android:name="com.example.lingo.ui.CardFragment"
        android:label="CardFragment"
        >
        <action
            android:id="@+id/action_card_to_quiz"
            app:destination="@+id/quizFragment"
            app:enterAnim="@android:anim/fade_in"
            app:exitAnim="@android:anim/fade_out"
            />
    </fragment>

    <fragment
        android:id="@+id/quizFragment"
        android:name="com.example.lingo.ui.QuizFragment"
        android:label="QuizFragment" >
        <action
            android:id="@+id/action_quiz_to_score"
            app:destination="@id/scoreFragment"
            app:enterAnim="@android:anim/fade_in"
            app:exitAnim="@android:anim/fade_out" />
    </fragment>

    <fragment
        android:id="@+id/scoreFragment"
        android:name="com.example.lingo.ui.ScoreFragment"
        android:label="ScoreFragment" >

        <action
            android:id="@+id/action_score_to_home"
            app:destination="@id/homeFragment"
            app:enterAnim="@android:anim/fade_in"
            app:exitAnim="@android:anim/fade_out"
            app:popUpTo="@id/homeFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
    android:id="@+id/settingsFragment"
    android:name="com.example.lingo.ui.SettingsFragment"
    android:label="SettingsFragment" />

    <fragment
    android:id="@+id/aboutFragment"
    android:name="com.example.lingo.ui.AboutFragment"
    android:label="AboutFragment" />




</navigation>